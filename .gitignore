# ============================================================
# Ambiguity Benchmark — .gitignore
# Experiment configs (configs/*.yaml) are intentionally TRACKED;
# only secrets and local overrides are ignored (see bottom).
# ============================================================

# --- Python bytecode / caches ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# --- Packaging / build artifacts ---
build/
dist/
*.egg-info/
*.egg

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Run outputs & scratch (regenerated by src.run / src.evaluate) ---
outputs/
multirun/
.hydra/
tmp/

# --- Secrets / credentials / API keys ---
.env
.env.*
*.env
secrets.*
*_secret*
*apikey*
*api_key*
credentials.json
service_account*.json

# --- Local config overrides (base configs/*.yaml remain tracked) ---
configs/*.local.yaml
configs/local.yaml
configs/secrets.yaml
configs/*.secret.yaml

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS cruft ---
.DS_Store
Thumbs.db

# --- Logs ---
*.log